import requests
from bs4 import BeautifulSoup

th = "https://job.id/search/?keywords=sales&location=DKI-Jakarta"
halaman = requests.get(th)
hasil = BeautifulSoup(halaman.content, 'html.parser')

# Cari semua class yang mengandung kata kunci
semua_class = set()
for tag in hasil.find_all(True):
    for c in tag.get("class", []):
        if any(kata in c.lower() for kata in ["job", "lowong", "card", "item", "list", "result", "ads"]):
            semua_class.add(c)

print("Class yang ditemukan:")
for c in sorted(semua_class):
    print(" -", c)

