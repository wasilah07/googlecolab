import requests
import pandas as pd
from bs4 import BeautifulSoup

th = "https://job.id/search/?keywords=sales&location=DKI-Jakarta"
halaman = requests.get(th)
hasil = BeautifulSoup(halaman.content, 'html.parser')

lowkers = hasil.find_all(class_="job-row")

posisi = []
instansi = []
lokasi = []
tipe = []
gaji = []
tanggal = []

for p in lowkers:
    # Ambil posisi
    posisi.append(p.select_one(".jr-title").get_text(strip=True))
    
    # Ambil instansi/perusahaan
    instansi.append(p.select_one(".jr-company").get_text(strip=True))
    
    # Ambil meta-pill (lokasi, tipe, gaji)
    pills = p.select(".meta-pill")
    
    # Lokasi (pill pertama)
    try:
        lokasi.append(pills[0].get_text(strip=True))
    except:
        lokasi.append("-")
    
    # Tipe pekerjaan (pill kedua)
    try:
        tipe.append(pills[1].get_text(strip=True))
    except:
        tipe.append("-")
    
    # Gaji (pill ketiga)
    try:
        xgaji = p.select_one(".salary").get_text(strip=True)
        xgaji = xgaji.replace("Rp", "").replace(",", "").strip()
    except:
        xgaji = "Dirahasiakan"
    gaji.append(xgaji)
    
    # Tanggal
    try:
        tanggal.append(p.select_one(".jr-date").get_text(strip=True))
    except:
        tanggal.append("-")

print(posisi)
print(instansi)
print(lokasi)
print(tipe)
print(gaji)
print(tanggal)

